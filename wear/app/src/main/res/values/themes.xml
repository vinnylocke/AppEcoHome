<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Wear apps host Compose inside a DeviceDefault theme; black window
         background avoids a white flash before Compose draws. -->
    <style name="RhozlyWearTheme" parent="@android:style/Theme.DeviceDefault">
        <item name="android:windowBackground">@android:color/black</item>
    </style>
</resources>
