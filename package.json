{
  "name": "appecohome---rebuild-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:isolation": "playwright test --project=isolation --workers=1 --pass-with-no-tests",
    "test:functions": "%USERPROFILE%\\.deno\\bin\\deno.exe test --allow-env --allow-net --env=.env.test --config supabase/tests/deno.json supabase/tests/",
    "test:all": "npm run test:unit && npm run test:functions && npm run test:e2e",
    "test:seed": "node scripts/seed-test-db.mjs --workers 4",
    "test:e2e:fresh": "npm run test:seed && playwright test --pass-with-no-tests",
    "deploy": "node scripts/deploy.mjs",
    "maintenance:off": "node scripts/clear-maintenance.mjs"
  },
  "dependencies": {
